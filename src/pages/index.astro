---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Self Esteem Love - Technical Studies About Confidence";
const description = "Research-based insights into self-esteem, confidence studies, and psychological science. Evidence-based analysis of self-worth and personal development.";
---
<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <div style="background: #ffffff; border: 4px solid #000000; margin: 3rem 0; padding: 4rem 3rem;">
    <div style="display: inline-block; font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 2rem; border: 3px solid #000000; padding: 0.5rem 1rem; background: #000000; color: #ffffff;">
      Research Archive
    </div>
    <h1 style="font-size: 4rem; font-weight: 700; line-height: 1.1; color: #000000; margin-bottom: 2rem; text-transform: uppercase; letter-spacing: -1px;">
      Confidence & Self-Esteem Research
    </h1>
    <p style="font-size: 1.2rem; color: #000000; margin-bottom: 3rem; max-width: 700px; line-height: 1.6; font-weight: 500;">
      A rigorous examination of self-esteem studies, confidence research, and psychological science. No marketing fluff—just peer-reviewed data, clinical findings, and evidence-based analysis.
    </p>
    <a href="/self-esteem/" style="display: inline-block; padding: 1rem 2.5rem; background: #000000; color: #ffffff; text-decoration: none; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border: 3px solid #000000; transition: all 0.2s;">
      Access Research
    </a>
  </div>

  <!-- Research Parameters -->
  <section style="padding: 3rem 0;">
    <div style="border-left: 8px solid #000000; padding-left: 2rem; margin-bottom: 3rem;">
      <div style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem;">Section 01</div>
      <h2 style="font-size: 3rem; font-weight: 700; color: #000000; text-transform: uppercase; letter-spacing: -1px;">Research Topics</h2>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">01</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">Overview</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Comprehensive introduction to self-esteem research, theoretical frameworks, and measurement methodologies.</p>
        <a href="/self-esteem/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
      
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">02</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">History</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Evolution of confidence studies from early psychology to modern neuroscientific research approaches.</p>
        <a href="/self-esteem/history/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
      
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">03</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">Technical</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Data-driven analysis of self-esteem measurement tools, statistical methods, and research protocols.</p>
        <a href="/self-esteem/technical-deep-dive/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
      
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">04</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">Glossary</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Key terminology, psychological constructs, and research vocabulary in self-esteem studies.</p>
        <a href="/self-esteem/ontology/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
      
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">05</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">Trends</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Current developments in confidence research, emerging findings, and future directions in the field.</p>
        <a href="/self-esteem/trends/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
      
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">06</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">Tools</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Assessment instruments, measurement scales, and resources for self-esteem evaluation and research.</p>
        <a href="/self-esteem/tools/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
      
      <div style="background: #ffffff; border: 4px solid #000000; padding: 2.5rem; position: relative;">
        <div style="position: absolute; top: -1.5rem; left: 2rem; font-size: 3rem; font-weight: 700; color: #000000; background: #f8f8f8; padding: 0 0.5rem;">07</div>
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #000000; margin-bottom: 1rem; text-transform: uppercase; margin-top: 1.5rem;">Challenges</h3>
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin-bottom: 1.5rem;">Research limitations, methodological challenges, and ongoing debates in self-esteem science.</p>
        <a href="/self-esteem/challenges/" style="color: #000000; font-weight: 700; text-transform: uppercase; text-decoration: none;">Read More &rarr;</a>
      </div>
    </div>
  </section>

  <section style="padding: 0 0 3rem 0;">
    <div style="max-width: 1000px; margin: 0 auto; padding: 0 2rem;">
      <div style="border-left: 8px solid #000000; padding-left: 2rem;">
        <p style="color: #000000; line-height: 1.6; font-weight: 500; margin: 0;">Building daily rituals that bring you joy is an essential part of self-care—discover how to master your morning with this <a href="https://completehomebarista.com/guides/pour-over-guide/">pour over coffee guide</a> for a mindful start to each day.</p>
      </div>
    </div>
  </section>
</BaseLayout>
