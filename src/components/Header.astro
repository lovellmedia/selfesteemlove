---
const { title } = Astro.props;
---
<header style="background: #ffffff; border: 4px solid #000000; border-left: none; border-right: none; padding: 1.5rem 0;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
    <a href="/" style="font-size: 1.3rem; font-weight: 700; color: #000000; text-decoration: none; text-transform: uppercase; letter-spacing: -0.5px;">Self Esteem Love</a>
    <nav>
      <ul style="list-style: none; display: flex; gap: 0; flex-wrap: wrap;">
        <li style="border-left: 3px solid #000000; padding: 0 1.5rem;"><a href="/" style="color: #000000; text-decoration: none; font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Home</a></li>
        <li style="border-left: 3px solid #000000; padding: 0 1.5rem;"><a href="/self-esteem/" style="color: #000000; text-decoration: none; font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Overview</a></li>
        <li style="border-left: 3px solid #000000; padding: 0 1.5rem;"><a href="/self-esteem/history/" style="color: #000000; text-decoration: none; font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">History</a></li>
        <li style="border-left: 3px solid #000000; padding: 0 1.5rem;"><a href="/self-esteem/technical-deep-dive/" style="color: #000000; text-decoration: none; font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Technical</a></li>
        <li style="border-left: 3px solid #000000; border-right: 3px solid #000000; padding: 0 1.5rem;"><a href="/self-esteem/trends/" style="color: #000000; text-decoration: none; font-size: 0.95rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Trends</a></li>
      </ul>
    </nav>
  </div>
</header>
<style>
  @media (max-width: 768px) {
    header nav ul { flex-direction: column; width: 100%; margin-top: 1rem; }
    header nav ul li { border-left: none; border-bottom: 3px solid #000000; padding: 0.75rem 0; }
    header nav ul li:last-child { border-right: none; }
  }
</style>
